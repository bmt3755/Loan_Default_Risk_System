# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.

# ---- Required ----
# The 5 checkers and the 2 sequential agents call the OpenAI API (gpt-4o-mini).
OPENAI_API_KEY=sk-your-openai-key-here

# ---- Optional: LangSmith tracing / observability ----
# Leave LANGSMITH_TRACING=false to run without tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2-your-langsmith-key-here
LANGSMITH_PROJECT=loan_default
